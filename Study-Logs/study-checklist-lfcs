[sudo firewall-cmd --zone=public --add-port=22/tcp --permanent OR sudo firewall-cmd --zone=public --add-service=ssh --permanent  
sudo firewall-cmd --zone=public --add-port=80/tcp --permanent OR sudo firewall-cmd --zone=public --add-service=http --permanent
sudo firewall-cmd --zone=public --add-port=9000/tcp --permanent]
